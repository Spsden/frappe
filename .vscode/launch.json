{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Attach FastAPI in Docker (:5678)",
      "type": "debugpy",
      "request": "attach",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/apps/api/src",
          "remoteRoot": "/app/src"
        }
      ],
      "justMyCode": true,
      "subProcess": true
    }
  ]
}
